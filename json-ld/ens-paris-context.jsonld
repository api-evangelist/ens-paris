  "@type": "CollegeOrUniversity",
  "name": "École Normale Supérieure de Paris",
  "url": "https://www.ens.psl.eu/en",
  "description": "Leading French grande école and constituent member of Université PSL. Programmatic data is reached via the HAL open archive (OAI-PMH and Search/REST APIs) and the MESR Opendatasoft Explore API.",
  "ror": "https://ror.org/05a0dhs15",
  "ens:apiCatalog": [
    {
      "@type": "Dataset",
      "name": "HAL-ENS Open Archive (OAI-PMH)",
