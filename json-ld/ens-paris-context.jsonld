    },
    {
      "@type": "Dataset",
      "name": "HAL Search / REST API",
      "url": "https://api.archives-ouvertes.fr/search/"
    },
    {
      "@type": "Dataset",
      "name": "MESR Higher Education Open Data (Explore API)",
